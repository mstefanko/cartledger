# CartLedger Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Server ---
# Port the server listens on (default: 8080)
PORT=8079

# Logging (log/slog). LOG_LEVEL=info (debug|info|warn|error), LOG_FORMAT=json (json|text)
# LOG_LEVEL=info
# LOG_FORMAT=json

# Data directory for SQLite DB and uploads (default: ./data)
DATA_DIR=./data

# --- Database (used by Docker Compose) ---
# Full path to SQLite database file inside the container
CARTLEDGER_DB_PATH=/data/cartledger.db

# Directory for receipt image uploads inside the container
CARTLEDGER_UPLOAD_DIR=/data/receipts

# --- LLM Provider ---
# Which LLM to use for receipt scanning:
#   ""           - auto-detect (API key → claude, else CLI → claude-cli, else mock)
#   "claude"     - direct Anthropic API (requires ANTHROPIC_API_KEY, billed per token)
#   "claude-cli" - spawns Claude Code CLI (uses your CLI subscription, no extra cost)
#   "gemini"     - Google Gemini API (requires GEMINI_API_KEY)
#   "mock"       - dummy data for testing without any AI
LLM_PROVIDER=

# Anthropic API key (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# Google Gemini API key (optional fallback, required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# --- Authentication ---
# Secret key for JWT token signing (change in production!)
JWT_SECRET=change-me-in-production

# --- Reverse proxy ---
# Trusted proxy CIDRs (comma-separated). Required behind Caddy/Nginx/Traefik
# for correct client IP and Secure-cookie detection. Safer to leave unset unless
# deploying behind a reverse proxy. Convenience: "loopback", "private", or explicit CIDRs.
# TRUST_PROXY=loopback

# --- Integrations ---
# Mealie, Tandoor, Grocy, etc. are now configured per-household in the UI at
# Settings -> Integrations. No env vars required.
#
# ALLOW_PRIVATE_INTEGRATIONS: set to "true" to permit integration base_urls
# that resolve to loopback / link-local / RFC1918 / IPv6 ULA addresses.
# Leave unset (default: false) to block SSRF probes of internal services.
# Self-hosters running Mealie at e.g. http://192.168.1.50:9925 should enable.
ALLOW_PRIVATE_INTEGRATIONS=false

# --- Image retention ---
# Self-hosted storage grows linearly with each scanned receipt. The retention
# janitor periodically deletes ORIGINAL receipt uploads under
# DATA_DIR/receipts/<uuid>/ whose mtime is older than IMAGE_RETENTION_DAYS.
# Preprocessed images (filenames starting with "processed_") are kept forever —
# the review UI depends on them. Reprocess (re-extraction) of a receipt whose
# original has been aged out will return 410 Gone.
#
# 0 (default) disables the janitor entirely. A reasonable self-host value is 90.
# IMAGE_RETENTION_DAYS=90
#
# How often the janitor walks DATA_DIR/receipts/ (Go duration, e.g. "24h", "6h").
# IMAGE_RETENTION_SWEEP_INTERVAL=24h
